<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MapMaker.App.ViewModels"
        xmlns:ws="clr-namespace:MapMaker.App.Views.Workspace"
        xmlns:conv="clr-namespace:MapMaker.App.Converters"
        x:Class="MapMaker.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Wicked MMO Map Editor"
        Width="1280" Height="720"
        MinWidth="800" MinHeight="600"
        Background="#1a1a1a">

    <Window.Resources>
        <conv:BoolToBackgroundConverter x:Key="BoolToBg"/>
    </Window.Resources>

    <DockPanel>

        <!-- Menyrad -->
        <Menu DockPanel.Dock="Top" Background="#2a2a2a">
            <MenuItem Header="File">
                <MenuItem Header="New Map"          Command="{Binding NewMapCommand}"        InputGesture="Ctrl+N"/>
                <MenuItem Header="Open Map"         Command="{Binding OpenMapCommand}"       InputGesture="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="Exit"             Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Undo" Command="{Binding UndoCommand}" InputGesture="Ctrl+Z"/>
                <MenuItem Header="Redo" Command="{Binding RedoCommand}" InputGesture="Ctrl+Y"/>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Show Grid"   Command="{Binding ToggleGridCommand}"/>
                <MenuItem Header="Show Spawns" Command="{Binding ToggleSpawnsCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Statusbar -->
        <Border DockPanel.Dock="Bottom" Background="#007acc" Padding="6,3">
            <Grid ColumnDefinitions="*,*,*">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           Foreground="White" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="{Binding CursorPosition}"
                           Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding MapInfo}"
                           Foreground="White" FontSize="12" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Huvud: sidopanel + workspace -->
        <Grid ColumnDefinitions="48,*">

            <!-- VS Code-style sidopanel -->
            <Border Grid.Column="0" Background="#2c2c2c">
                <StackPanel Orientation="Vertical" Spacing="2" Margin="4">

                    <Button Command="{Binding Workspace.SetSpritesCommand}"
                            ToolTip.Tip="Sprites"
                            Width="40" Height="40" Padding="0"
                            HorizontalContentAlignment="Center"
                            Background="{Binding Workspace.IsSprites, Converter={StaticResource BoolToBg}}"
                            BorderThickness="0">
                        <TextBlock Text="🎨" FontSize="20"/>
                    </Button>

                    <Button Command="{Binding Workspace.SetItemsCommand}"
                            ToolTip.Tip="Items"
                            Width="40" Height="40" Padding="0"
                            HorizontalContentAlignment="Center"
                            Background="{Binding Workspace.IsItems, Converter={StaticResource BoolToBg}}"
                            BorderThickness="0">
                        <TextBlock Text="⚔️" FontSize="20"/>
                    </Button>

                    <Button Command="{Binding Workspace.SetMapCommand}"
                            ToolTip.Tip="Map Editor"
                            Width="40" Height="40" Padding="0"
                            HorizontalContentAlignment="Center"
                            Background="{Binding Workspace.IsMap, Converter={StaticResource BoolToBg}}"
                            BorderThickness="0">
                        <TextBlock Text="🗺️" FontSize="20"/>
                    </Button>

                </StackPanel>
            </Border>

            <!-- Workspace -->
            <Grid Grid.Column="1">
                <ws:SpriteWorkspace IsVisible="{Binding Workspace.IsSprites}"/>
                <ws:ItemWorkspace   IsVisible="{Binding Workspace.IsItems}"/>
                <ws:MapWorkspace    IsVisible="{Binding Workspace.IsMap}"/>
            </Grid>

        </Grid>
    </DockPanel>
</Window>