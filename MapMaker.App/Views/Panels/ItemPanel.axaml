<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MapMaker.App.ViewModels"
             x:Class="MapMaker.App.Views.Panels.ItemPanel"
             x:DataType="vm:ItemPanelViewModel">
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Items"
                   Foreground="White" FontWeight="Bold" Margin="6,4"/>
        <Border DockPanel.Dock="Top" Height="1" Background="#444" Margin="0,2"/>
        <TextBlock Text="Inga items." Foreground="#555"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </DockPanel>
</UserControl>