<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MapMaker.App.ViewModels"
             xmlns:sprites="clr-namespace:MapMaker.Core.Sprites;assembly=MapMaker.Core"
             xmlns:map="clr-namespace:MapMaker.Core.Map;assembly=MapMaker.Core"
             xmlns:conv="clr-namespace:MapMaker.App.Converters"
             xmlns:controls="clr-namespace:MapMaker.App.Views.Controls"
             x:Class="MapMaker.App.Views.Workspace.MapWorkspace"
             x:DataType="vm:MapWorkspaceViewModel">

    <UserControl.Resources>
        <conv:SpriteToBitmapConverter x:Key="SpriteToBitmap"/>
    </UserControl.Resources>

    <Grid ColumnDefinitions="180,*,200">

        <!-- Vänster: Sprite-picker -->
        <DockPanel Grid.Column="0" Background="#252525">
            <Border DockPanel.Dock="Top" Padding="8,6" Background="#2c2c2c">
                <TextBlock Text="SPRITES" Foreground="#aaa"
                           FontSize="11" FontWeight="Bold" LetterSpacing="2"/>
            </Border>
            <ListBox ItemsSource="{Binding Sprites}"
                     SelectedItem="{Binding SelectedSprite}"
                     Background="#252525">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="sprites:SpriteEntry">
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="2">
                            <Image Width="32" Height="32"
                                   Source="{Binding ., Converter={StaticResource SpriteToBitmap}}"
                                   RenderOptions.BitmapInterpolationMode="None"/>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="White" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Mitten: Canvas -->
        <DockPanel Grid.Column="1" Background="#1e1e1e">

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="#2a2a2a" Padding="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ToggleButton Content="🔲 Grid"
                                  IsChecked="{Binding ShowGrid}"
                                  FontSize="11"/>
                    <Separator Width="1" Background="#444"/>
                    <TextBlock Text="Brush:" Foreground="#aaa"
                               FontSize="11" VerticalAlignment="Center"/>
                    <Button Content="－" Command="{Binding DecreaseBrushCommand}" Width="28"/>
                    <TextBlock Text="{Binding BrushSize}" Foreground="White"
                               FontSize="12" VerticalAlignment="Center" Width="20"
                               TextAlignment="Center"/>
                    <Button Content="＋" Command="{Binding IncreaseBrushCommand}" Width="28"/>
                    <Separator Width="1" Background="#444"/>
                    <TextBlock Text="{Binding ZoomLabel}" Foreground="#aaa"
                               FontSize="11" VerticalAlignment="Center"/>
                    <Separator Width="1" Background="#444"/>
                    <TextBlock Text="{Binding CursorPosition}" Foreground="#aaa"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <controls:MapCanvas Name="Canvas"/>
        </DockPanel>

        <!-- Höger: Lager -->
        <DockPanel Grid.Column="2" Background="#252525">
            <Border DockPanel.Dock="Top" Padding="8,6" Background="#2c2c2c">
                <TextBlock Text="LAGER" Foreground="#aaa"
                           FontSize="11" FontWeight="Bold" LetterSpacing="2"/>
            </Border>
            <ListBox ItemsSource="{Binding Layers}"
                     SelectedItem="{Binding ActiveLayer}"
                     Background="#252525">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="map:MapLayer">
                        <TextBlock Text="{Binding Name}"
                                   Foreground="White" FontSize="12" Margin="4"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

    </Grid>
</UserControl>