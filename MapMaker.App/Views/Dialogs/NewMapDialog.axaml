<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MapMaker.App.ViewModels"
        x:Class="MapMaker.App.Views.Dialogs.NewMapDialog"
        x:DataType="vm:NewMapDialogViewModel"
        Title="Ny karta"
        Width="340" Height="260"
        CanResize="false"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20" Spacing="12">

        <TextBlock Text="Skapa ny karta" FontSize="16" FontWeight="Bold"/>

        <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto,Auto" >

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Namn:"
                       VerticalAlignment="Center"/>
            <TextBox   Grid.Row="0" Grid.Column="1"
                       Text="{Binding MapName}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Bredd (tiles):"
                       VerticalAlignment="Center" Margin="0,8,0,0"/>
            <NumericUpDown Grid.Row="1" Grid.Column="1"
                           Value="{Binding Width}"
                           Minimum="10" Maximum="32000"
                           Margin="0,8,0,0"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Höjd (tiles):"
                       VerticalAlignment="Center" Margin="0,8,0,0"/>
            <NumericUpDown Grid.Row="2" Grid.Column="1"
                           Value="{Binding Height}"
                           Minimum="10" Maximum="32000"
                           Margin="0,8,0,0"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Tile-storlek:"
                       VerticalAlignment="Center" Margin="0,8,0,0"/>
            <NumericUpDown Grid.Row="3" Grid.Column="1"
                           Value="{Binding TileSize}"
                           Minimum="8" Maximum="128"
                           Margin="0,8,0,0"/>
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" 
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Avbryt" Command="{Binding CancelCommand}"/>
            <Button Content="Skapa"  Command="{Binding CreateCommand}"/>
        </StackPanel>

    </StackPanel>
</Window>