<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MapMaker.App.ViewModels"
        x:Class="MapMaker.App.Views.Dialogs.ImportSpriteDialog"
        x:DataType="vm:ImportSpriteDialogViewModel"
        Title="Importera sprites"
        Width="380" Height="360"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20" Spacing="12">

        <TextBlock Text="Importera sprites" FontSize="16" FontWeight="Bold"/>

        <!-- Filval -->
        <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0" Text="{Binding FileName}"
                     IsReadOnly="True" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Bläddra"
                    Command="{Binding BrowseCommand}" Margin="8,0,0,0"/>
        </Grid>

        <!-- Läge -->
        <StackPanel Orientation="Horizontal" Spacing="16">
            <RadioButton Content="Enskild sprite"
                         IsChecked="{Binding IsSheet, Converter={x:Static BoolConverters.Not}}"/>
            <RadioButton Content="Sprite sheet"
                         IsChecked="{Binding IsSheet}"/>
        </StackPanel>

        <!-- Sheet-inställningar -->
        <Border IsVisible="{Binding IsSheet}"
                BorderBrush="#444" BorderThickness="1"
                Padding="12" CornerRadius="4">
            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto">

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Tile bredd (px):"
                           VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="0" Grid.Column="1"
                               Value="{Binding TileWidth}"
                               Minimum="1" Maximum="512"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Tile höjd (px):"
                           VerticalAlignment="Center" Margin="0,8,0,0"/>
                <NumericUpDown Grid.Row="1" Grid.Column="1"
                               Value="{Binding TileHeight}"
                               Minimum="1" Maximum="512" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Kolumner:"
                           VerticalAlignment="Center" Margin="0,8,0,0"/>
                <NumericUpDown Grid.Row="2" Grid.Column="1"
                               Value="{Binding Columns}"
                               Minimum="1" Maximum="512" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Rader:"
                           VerticalAlignment="Center" Margin="0,8,0,0"/>
                <NumericUpDown Grid.Row="3" Grid.Column="1"
                               Value="{Binding Rows}"
                               Minimum="1" Maximum="512" Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <!-- Knappar -->
        <StackPanel Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Avbryt"    Command="{Binding CancelCommand}"/>
            <Button Content="Importera" Command="{Binding ImportCommand}"/>
        </StackPanel>

    </StackPanel>
</Window>